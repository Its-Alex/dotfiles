  "agent": {
    "dev": {
      "description": "Pragmatic senior developer — direct, concrete, actionable answers",
      "mode": "primary",
      "model": "cursor-acp/auto",
      "prompt": "Act as a pragmatic senior developer.\n\nGoal:\nGive directly useful, concrete, and quickly applicable answers.\n\nConstraints:\n- Get straight to the point (no fluff)\n- Provide concrete examples (code, commands, config)\n- If multiple options exist, give the best default + quick alternatives\n- Briefly explain the \"why\" only when useful\n- Prioritize simple, robust, maintainable solutions\n- Avoid unnecessary abstractions\n\nExpected format:\n1. Main solution (clear and fast)\n2. Concrete example (code or command)\n3. Alternatives (if relevant)\n4. Pitfalls / things to watch (if important)\n\nBehavior:\n- If the request is unclear, ask ONE targeted question max\n- If I make a mistake or bad choice, correct me clearly\n- Adapt detail level: concise by default, detailed if I ask\n- Assume I'm technical (no need to explain basics)"
    }
  },
{{- if and (ne (env "CHEZMOI_PASSWORD_MANAGER_DISABLED") "true") (ne (env "CHEZMOI_PASSWORD_MANAGER_DISABLED") "1") }}
  "mcp": {
    "mcp-atlassian": {
      "type": "local",
      "enabled": true,
      "command": [
        "podman",
        "run",
        "-i",
        "--rm",
        "-e",
        "CONFLUENCE_URL",
        "-e",
        "CONFLUENCE_USERNAME",
        "-e",
        "CONFLUENCE_API_TOKEN",
        "-e",
        "JIRA_URL",
        "-e",
        "JIRA_USERNAME",
        "-e",
        "JIRA_API_TOKEN",
        "ghcr.io/sooperset/mcp-atlassian:latest"
      ],
      "environment": {
        "CONFLUENCE_URL": "{{ (bitwardenFields "item" "Confluence - API Token").space_url.value }}",
        "CONFLUENCE_USERNAME": "{{ (bitwarden "item" "Confluence - API Token").login.username }}",
        "CONFLUENCE_API_TOKEN": "{{ (bitwarden "item" "Confluence - API Token").login.password }}",
        "JIRA_URL": "{{ (bitwardenFields "item" "Jira - API Token ").space_url.value }}",
        "JIRA_USERNAME": "{{ (bitwarden "item" "Jira - API Token ").login.username }}",
        "JIRA_API_TOKEN": "{{ (bitwarden "item" "Jira - API Token ").login.password }}"
      }
    }
  }
{{- end }}
