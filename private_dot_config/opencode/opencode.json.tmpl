  "mcp": {
    "mcp-atlassian": {
      "type": "local",
      "enabled": true,
      "command": [
        "mise",
        "exec",
        "--",
        "mcp-atlassian"
      ],
      "environment": {
        "CONFLUENCE_URL": "{{ (bitwardenFields "item" "Confluence - API Token").space_url.value }}",
        "CONFLUENCE_USERNAME": "{{ (bitwarden "item" "Confluence - API Token").login.username }}",
        "CONFLUENCE_API_TOKEN": "{{ (bitwarden "item" "Confluence - API Token").login.password }}",
        "JIRA_URL": "{{ (bitwardenFields "item" "Jira - API Token ").space_url.value }}",
        "JIRA_USERNAME": "{{ (bitwarden "item" "Jira - API Token ").login.username }}",
        "JIRA_API_TOKEN": "{{ (bitwarden "item" "Jira - API Token ").login.password }}"
      }
    }
  }
{{- end }}
